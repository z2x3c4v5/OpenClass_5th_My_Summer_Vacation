rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자(선생님)인지 확인 — firebase-config.js 의 ADMIN_EMAIL 과 같아야 함
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'fglucky35@gmail.com';
    }

    // 본인인지 확인
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /students/{uid} {
      // 학생은 자기 문서만 읽기/쓰기, 관리자는 모든 학생 문서 읽기 + 삭제 가능
      allow read:   if isAdmin() || isOwner(uid);
      allow write:  if isOwner(uid);
      allow delete: if isAdmin() || isOwner(uid);

      // events / practice / liveState 등 모든 하위 문서도 동일 규칙
      match /{document=**} {
        allow read:   if isAdmin() || isOwner(uid);
        allow write:  if isOwner(uid);
        allow delete: if isAdmin() || isOwner(uid);
      }
    }

    // 대시보드의 "전체 활동 피드"는 모든 학생의 events를 한꺼번에 읽는
    // 컬렉션 그룹 쿼리라서, 관리자 전용 규칙을 따로 둬야 동작합니다.
    match /{path=**}/events/{eventId} {
      allow read: if isAdmin();
    }

    // 자리 배치 등 교사 설정 — 관리자만 읽기/쓰기 (기기 간 유지)
    match /config/{doc} {
      allow read, write: if isAdmin();
    }
  }
}
