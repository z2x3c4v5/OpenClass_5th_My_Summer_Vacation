rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자(선생님)인지 확인 — firebase-config.js 의 ADMIN_EMAIL 과 같아야 함
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'fglucky35@gmail.com';
    }

    // 본인인지 확인
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /students/{uid} {
      // 학생은 자기 문서만 읽기/쓰기, 관리자는 모든 학생 문서 읽기 가능
      allow read:  if isAdmin() || isOwner(uid);
      allow write: if isOwner(uid);

      // events / practice / liveState 등 모든 하위 문서도 동일 규칙
      match /{document=**} {
        allow read:  if isAdmin() || isOwner(uid);
        allow write: if isOwner(uid);
      }
    }
  }
}
